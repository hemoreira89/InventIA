{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/cotacoes.js": {
      "maxDuration": 10
    },
    "api/fundamentos.js": {
      "maxDuration": 10
    },
    "api/historico.js": {
      "maxDuration": 8
    },
    "api/cron-screening.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron-screening",
      "schedule": "0 6 * * *"
    }
  ]
}
